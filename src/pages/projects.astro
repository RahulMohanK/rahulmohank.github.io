---
import Footer from "../components/footer.astro";
import Header from "../components/header.astro";

const data = [
        { title: 'BrowseNest', desc: 'Smart bookmarks bar manager.', tags: ['React','Typescript','HTML','CSS'], link : "https://chromewebstore.google.com/detail/browsenest/gbkjnhbfnhgbffiphpbnakfejkiccgpg" },
        { title: 'Gofr', desc: 'OSS contribution to gofr microservice framework', tags: ['Go'], link: "https://github.com/gofr-dev/gofr/pull/1061" },
      ];
---
<html lang="en">
    <head>
          <!-- Google tag (gtag.js) -->
    <script type="text/partytown" async src="https://www.googletagmanager.com/gtag/js?id=G-MYEQ18716P"></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-MYEQ18716P');
    </script>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Rahul Mohan K</title>
    </head>
<body>
<Header/>
   <section id="panel-home" class="panel" role="tabpanel" aria-labelledby="tab-home">
        <div class="center wrap">
          <!-- <h1>Projects</h1> -->
          <p class="lead">A few small, focused builds.</p>
          <div class="projects" id="projects">
            {
                data.map((project: any)=>(
                    <article class="card">
                    <a href={project.link}  target="_blank" rel="noopener noreferrer">
                        <h3>{project.title}</h3>
                        <p>{project.desc}</p>
                        <div class="tags">{(project.tags||[]).map((tag:any)=>(<span class="tag">{tag}</span>))}</div>
                      </a>
                    </article>
                ))
            }
          </div>
        </div>
      </section>
    <Footer/>
</body>
</html>